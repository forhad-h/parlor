# ═══════════════════════════════════════════════════════════════════════════
#  Parlor Bengali service — quick start
# ═══════════════════════════════════════════════════════════════════════════
#  1. cp .env.example .env
#  2. Paste a free key below (https://aistudio.google.com/apikey)
#  3. npm start
#
#  No key yet? Set LLM_PROVIDER=mock instead and skip step 2 — the whole app
#  runs end-to-end with zero credentials (real Edge TTS still speaks).
#
#  Everything past the divider below is optional. Defaults already work —
#  only touch it if you know why. Full details: service/README.md § Configuration.
# ═══════════════════════════════════════════════════════════════════════════

GEMINI_API_KEY=

# ═══════════════════════════ optional below this line ═══════════════════════

# ── Provider choice ──────────────────────────────────────────────────────────
LLM_PROVIDER=gemini       # gemini | openrouter | mock
TTS_PROVIDER=edge         # edge is the only one implemented today

# ── Only needed when LLM_PROVIDER=openrouter ────────────────────────────────
OPENROUTER_API_KEY=                             # get one at https://openrouter.ai/keys
OPENROUTER_MODEL=google/gemini-2.5-flash        # cost/quality dial — keep an audio+JSON-schema-capable model

# ── Fine-tuning (safe to leave alone) ───────────────────────────────────────
PORT=3001                        # port this service listens on (server.py calls it here)
LOG_LEVEL=info                   # error | warn | info | debug
GEMINI_MODEL=gemini-2.5-flash    # 2.0-flash also works, but its free tier often hits 0 quota
LLM_TEMPERATURE=0.7              # 0 = focused/deterministic, 1 = more varied replies
TTS_VOICE=bn-BD-PradeepNeural    # also: bn-BD-NabanitaNeural, bn-IN-TanishaaNeural, bn-IN-BashkarNeural
TTS_RATE=+0%                     # speaking speed as an SSML-style delta, e.g. "-10%"
TTS_PITCH=+0Hz                   # voice pitch as an SSML-style delta, e.g. "-5Hz"
MAX_REQUEST_MB=12                # reject audio/image payloads larger than this
CACHE_TTS=true                   # cache identical Bengali sentences (latency + quota saver)

# ── Safety (optional) ────────────────────────────────────────────────────────
# The primary safety layer is the prompt rule (always on, all providers). This
# knob controls the SECONDARY layers on both sides of a turn — the input-side
# prompt-injection heuristic (middleware/promptInjectionGuard.js) and the
# output-side Gemini safety classifier — and is an env var rather than
# hardcoded on purpose: enforcement needs a staged rollout — log first, measure
# the false-positive rate on Bengali, then flip to block — and a bad call needs
# an instant revert. That should be a restart, not a deploy.
#
# log | block — 'log' only warns; 'block' skips the LLM call and speaks a
# Bengali refusal for flagged input, or swaps in a refusal for flagged output.
# Default 'log': both signals are heuristics/classifiers weaker on Bengali than
# the prompt rule, so measure their false-positive rate before enforcing.
# SAFETY_MODE=log
