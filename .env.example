# Nothing here is REQUIRED — every value has a working default. The one
# actual key you need to fill in (GEMINI_API_KEY) lives in service/.env.example
# since hosted mode is the default.

# [optional] Path to a local Gemma 4 E2B model — auto-downloads from HuggingFace
# if not set. Used only in on-device mode (NODE_SERVICE_URL set to empty below).
# Ignored in the default hosted/Bengali mode.
# MODEL_PATH=/path/to/gemma-4-E2B-it.litertlm

# [optional] Server port (default: 8000)
# PORT=8000

# ── Hosted / Bengali mode [optional, default shown] ─────────────────────────
# Hosted Bengali mode is the default — this points at the Node service
# (service/); the LLM + TTS run there and this process skips loading the
# on-device models. It needs the Node service running with a valid API key
# (see service/.env.example) or every turn will fail.
# To opt into the original, fully on-device English path instead, set this
# to empty: NODE_SERVICE_URL=
NODE_SERVICE_URL=http://localhost:3001
