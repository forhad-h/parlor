# Path to a local Gemma 4 E2B model (optional — auto-downloads from HuggingFace if not set)
# MODEL_PATH=/path/to/gemma-4-E2B-it.litertlm

# Server port (default: 8000)
# PORT=8000

# LiteRT-LM backend: GPU (default on macOS) or CPU (default everywhere else,
# including Docker — containers can't access the host GPU)
# LITERT_BACKEND=CPU
